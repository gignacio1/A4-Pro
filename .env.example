# ============================================================
# Sistema A4 PRO — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Conexão com o PostgreSQL (obrigatório)
# Formato: postgresql://usuario:senha@host:porta/banco
DATABASE_URL=postgresql://postgres:senha@localhost:5432/sistema_a4

# Segredo de sessão — gere com: openssl rand -hex 32
SESSION_SECRET=troque_por_uma_string_longa_e_aleatoria

# Ambiente (development | production)
NODE_ENV=production
